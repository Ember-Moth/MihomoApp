<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Aureline.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="760"
             x:Name="Root"
             x:Class="Aureline.Views.Pages.ProxiesPageView"
             x:DataType="vm:MainViewModel">
    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0"
                Padding="16,12,16,10"
                Background="{DynamicResource Brush.PageBackground}"
                BorderBrush="{DynamicResource Brush.StrokeMuted}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding SelectedGroupTitle}"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="20"
                                   FontWeight="Black"
                                   MaxLines="1"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding SelectedGroupSummary}"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="12"
                                   MaxLines="1"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Top">
                        <Button Classes="iconButton"
                                Width="44"
                                Height="44"
                                Content="⌕"
                                Command="{Binding ToggleProxySearchCommand}" />
                        <Button Classes="iconButton"
                                Width="44"
                                Height="44"
                                Content="↻"
                                Command="{Binding RefreshSelectedGroupCommand}" />
                        <Button Classes="iconButton"
                                Width="44"
                                Height="44"
                                Content="⋯">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="测试当前策略"
                                              Command="{Binding TestSelectedGroupDelayCommand}" />
                                    <MenuItem Header="定位当前节点"
                                              Command="{Binding ShowCurrentProxyCommand}" />
                                    <MenuItem Header="配置顺序"
                                              Command="{Binding SetProxySortModeCommand}"
                                              CommandParameter="配置顺序" />
                                    <MenuItem Header="按延迟"
                                              Command="{Binding SetProxySortModeCommand}"
                                              CommandParameter="按延迟" />
                                    <MenuItem Header="按名称"
                                              Command="{Binding SetProxySortModeCommand}"
                                              CommandParameter="按名称" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>

                <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ProxyGroups}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProxyGroupItem">
                                <Button Classes="groupTab"
                                        Classes.active="{Binding IsSelected}"
                                        MinWidth="132"
                                        Margin="0,0,8,0"
                                        Command="{Binding DataContext.SelectGroupCommand, ElementName=Root}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding CountText}"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   FontSize="11" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                IsVisible="{Binding IsProxySearchVisible}"
                Padding="16,10"
                Background="{DynamicResource Brush.PageBackground}"
                BorderBrush="{DynamicResource Brush.StrokeMuted}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <TextBox Text="{Binding ProxySearchText}"
                         PlaceholderText="搜索节点、类型或链路" />
                <Button Grid.Column="1"
                        Classes="iconButton"
                        Content="×"
                        Command="{Binding ClearProxySearchCommand}" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      x:Name="ProxyPageHost"
                      RenderTransformOrigin="0.5,0.5">
            <StackPanel Margin="16,16,16,112"
                        Spacing="12">
                <Border Classes="card"
                        IsVisible="{Binding MissingSelectedGroup}">
                    <StackPanel Spacing="8"
                                HorizontalAlignment="Center">
                        <TextBlock Text="暂无策略"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding SelectedGroupSummary}"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Classes="card"
                        IsVisible="{Binding MissingVisibleProxyNodes}">
                    <TextBlock Text="没有匹配的节点"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               HorizontalAlignment="Center" />
                </Border>

                <ItemsControl ItemsSource="{Binding VisibleProxyNodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProxyNodeItem">
                            <Button Classes="listItemButton"
                                    Classes.active="{Binding IsSelected}"
                                    MinHeight="74"
                                    Margin="0,0,0,8"
                                    Command="{Binding DataContext.SelectProxyCommand, ElementName=Root}"
                                    CommandParameter="{Binding}">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <StackPanel Spacing="5"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   FontSize="12"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <Border Classes="delayChip">
                                            <TextBlock Text="{Binding DelayText}"
                                                       Foreground="{DynamicResource Brush.Warning}"
                                                       FontSize="12" />
                                        </Border>
                                        <Border Width="22"
                                                Height="22"
                                                CornerRadius="8"
                                                Background="{DynamicResource Brush.Route}"
                                                IsVisible="{Binding IsSelected}">
                                            <TextBlock Text="✓"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.RouteForeground}"
                                                       FontSize="12"
                                                       FontWeight="Black" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
