<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Aureline.Views.Controls"
             xmlns:vm="using:Aureline.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="760"
             x:Class="Aureline.Views.Pages.OverviewPageView"
             x:DataType="vm:MainViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,8,12,12"
                    Spacing="10">
            <Border Classes="dashboardCard"
                    MinHeight="0">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <StackPanel Spacing="7">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Border Classes="statusPill"
                                        Classes.success="{Binding IsRunning}"
                                        Classes.warning="{Binding IsStarting}"
                                        Padding="10,5">
                                    <TextBlock Text="{Binding StateText}"
                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border Classes="statusPill route"
                                        Padding="10,5">
                                    <TextBlock Text="{Binding OutboundModeTitle}"
                                               Foreground="{DynamicResource Brush.Route}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{Binding RunningStateText}"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="24"
                                       FontWeight="Black"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Text="{Binding OverviewStatusSummary}"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="12"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Classes="startFab"
                                Classes.running="{Binding IsRunning}"
                                MinWidth="82"
                                MinHeight="52"
                                VerticalAlignment="Top"
                                Command="{Binding RunningActionCommand}">
                            <TextBlock Text="{Binding RunningActionText}"
                                       FontSize="16"
                                       FontWeight="Black" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="10">
                        <TextBlock Text="出站模式"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <Grid Grid.Column="1"
                              ColumnDefinitions="*,*,*"
                              ColumnSpacing="6">
                            <Button Classes="outboundMode"
                                    Classes.active="{Binding IsRuleMode}"
                                    HorizontalContentAlignment="Center"
                                    Content="Rule"
                                    Command="{Binding ChangeOutboundModeCommand}"
                                    CommandParameter="rule" />
                            <Button Grid.Column="1"
                                    Classes="outboundMode"
                                    Classes.active="{Binding IsGlobalMode}"
                                    HorizontalContentAlignment="Center"
                                    Content="Global"
                                    Command="{Binding ChangeOutboundModeCommand}"
                                    CommandParameter="global" />
                            <Button Grid.Column="2"
                                    Classes="outboundMode"
                                    Classes.active="{Binding IsDirectMode}"
                                    HorizontalContentAlignment="Center"
                                    Content="Direct"
                                    Command="{Binding ChangeOutboundModeCommand}"
                                    CommandParameter="direct" />
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="14"
                          RowSpacing="8">
                        <StackPanel Spacing="2">
                            <TextBlock Text="当前配置"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="11" />
                            <TextBlock Text="{Binding CurrentConfigDisplayName}"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="2">
                            <TextBlock Text="默认策略"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="11" />
                            <TextBlock Text="{Binding SelectedGroupNow}"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Spacing="2">
                            <TextBlock Text="内网地址"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="11" />
                            <TextBlock Text="{Binding VpnIntranetAddress}"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Spacing="2">
                            <TextBlock Text="连接数"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="11" />
                            <TextBlock Text="{Binding ConnectionCount}"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Classes="dashboardCard"
                    Height="208"
                    MinHeight="0">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="8">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <StackPanel Spacing="3">
                            <TextBlock Text="实时链路"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="18"
                                       FontWeight="Black" />
                            <TextBlock Text="最近 30 秒上传和下载速率"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="12" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Top">
                            <StackPanel Spacing="2"
                                        HorizontalAlignment="Right">
                                <TextBlock Text="上传"
                                           Foreground="{DynamicResource Brush.ChartUpload}"
                                           FontSize="11"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding UploadSpeed}"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                            <StackPanel Spacing="2"
                                        HorizontalAlignment="Right">
                                <TextBlock Text="下载"
                                           Foreground="{DynamicResource Brush.ChartDownload}"
                                           FontSize="11"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding DownloadSpeed}"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <controls:SpeedChart Grid.Row="1"
                                         PrimarySamples="{Binding DownloadSpeedSamples}"
                                         SecondarySamples="{Binding UploadSpeedSamples}"
                                         PrimaryStroke="{DynamicResource Brush.ChartDownload}"
                                         SecondaryStroke="{DynamicResource Brush.ChartUpload}" />
                </Grid>
            </Border>

            <Border Classes="dashboardCard"
                    MinHeight="0">
                <Grid RowDefinitions="Auto,Auto"
                      RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <StackPanel Spacing="3">
                            <TextBlock Text="网络检测"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="18"
                                       FontWeight="Black" />
                            <TextBlock Text="{Binding NetworkDetectionRouteText}"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="12" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Classes="iconButton"
                                Width="42"
                                Height="42"
                                Content="↻"
                                Command="{Binding RefreshNetworkDetectionCommand}" />
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                        <TextBlock Text="{Binding PublicIpCountryMark}"
                                   Foreground="{DynamicResource Brush.Route}"
                                   FontSize="24"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1"
                                    Spacing="3">
                            <TextBlock Text="{Binding NetworkDetectionStateText}"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="20"
                                       FontWeight="Black"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding NetworkDetectionDetailText}"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="11"
                                       MaxLines="2"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
