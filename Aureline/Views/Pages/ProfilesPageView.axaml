<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Aureline.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="760"
             x:Class="Aureline.Views.Pages.ProfilesPageView"
             x:DataType="vm:MainViewModel">
    <ScrollViewer>
        <StackPanel Margin="16,14,16,96"
                    Spacing="14">
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="3">
                        <TextBlock Text="远程订阅"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="使用 clash UA 拉取并写入当前 config.yaml"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="12" />
                    </StackPanel>

                    <Border Classes="settingRow">
                        <StackPanel Spacing="8">
                            <TextBlock Text="订阅地址"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                            <TextBox Text="{Binding SubscriptionUrl}"
                                     PlaceholderText="https://example.com/sub.yaml" />
                        </StackPanel>
                    </Border>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button Classes="primary"
                                Content="导入订阅"
                                Command="{Binding ImportSubscriptionCommand}" />
                        <Button Grid.Column="1"
                                Content="校验配置"
                                Command="{Binding ValidateConfigCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="12">
                    <StackPanel Spacing="3">
                        <TextBlock Text="本地配置"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding LastMessage}"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="12"
                                   MaxLines="2"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Classes="settingRow">
                        <StackPanel Spacing="8">
                            <TextBlock Text="config.yaml"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                            <TextBox Text="{Binding ConfigPath}"
                                     PlaceholderText="/data/user/0/.../files/config.yaml" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,*,*"
                          ColumnSpacing="8">
                        <Button Content="保存"
                                Command="{Binding SaveConfigCommand}" />
                        <Button Grid.Column="1"
                                Content="重载"
                                Command="{Binding ReloadConfigCommand}" />
                        <Button Grid.Column="2"
                                Classes="danger"
                                Content="重置"
                                Command="{Binding ResetConfigCommand}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="运行目录"
                               Foreground="{DynamicResource Brush.TextPrimary}"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <Border Classes="settingRow">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Border Width="38"
                                    Height="38"
                                    CornerRadius="19"
                                    Background="{DynamicResource Brush.InfoSurface}">
                                <TextBlock Text="H"
                                           Foreground="{DynamicResource Brush.Info}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="3">
                                <TextBlock Text="Home"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12" />
                                <TextBlock Text="{Binding HomeDirectory}"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="13"
                                           MaxLines="2"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
