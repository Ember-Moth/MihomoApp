<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Aureline.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="760"
             x:Name="Root"
             x:Class="Aureline.Views.Pages.ToolsPageView"
             x:DataType="vm:MainViewModel">
    <Grid x:Name="ToolContentHost"
          RenderTransformOrigin="0.5,0.5">
        <ScrollViewer IsVisible="{Binding IsToolsRootPage}">
            <StackPanel Margin="0,0,0,96">
                <TextBlock Classes="sectionHeader"
                           Text="设置" />

                <Button Classes="toolRow">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Border Classes="leadingIcon">
                            <TextBlock Text="文"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontWeight="Black" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Spacing="3">
                            <TextBlock Text="语言"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="{Binding LocaleText}"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="20" />
                    </Grid>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="默认"
                                      Command="{Binding SetLocaleCommand}"
                                      CommandParameter="" />
                            <MenuItem Header="简体中文"
                                      Command="{Binding SetLocaleCommand}"
                                      CommandParameter="zh-Hans" />
                            <MenuItem Header="English"
                                      Command="{Binding SetLocaleCommand}"
                                      CommandParameter="en" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button Classes="toolRow"
                        Command="{Binding ShowToolPageCommand}"
                        CommandParameter="theme">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Border Classes="leadingIcon">
                            <TextBlock Text="◐"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Spacing="3">
                            <TextBlock Text="主题"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="设置深色模式，调整色彩"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="20" />
                    </Grid>
                </Button>

                <Button Classes="toolRow"
                        Command="{Binding ShowToolPageCommand}"
                        CommandParameter="backup">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Border Classes="leadingIcon">
                            <TextBlock Text="☁"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Spacing="3">
                            <TextBlock Text="备份与恢复"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="通过WebDAV或者文件同步数据"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="20" />
                    </Grid>
                </Button>

                <Button Classes="toolRow"
                        Command="{Binding ShowToolPageCommand}"
                        CommandParameter="access">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Border Classes="leadingIcon">
                            <TextBlock Text="☷"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Spacing="3">
                            <TextBlock Text="访问控制"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="配置应用访问代理"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="20" />
                    </Grid>
                </Button>

                <Button Classes="toolRow"
                        Command="{Binding ShowToolPageCommand}"
                        CommandParameter="basic">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Border Classes="leadingIcon">
                            <TextBlock Text="✎"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Spacing="3">
                            <TextBlock Text="基本配置"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="全局修改基本配置"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="20" />
                    </Grid>
                </Button>

                <Button Classes="toolRow"
                        Command="{Binding ShowToolPageCommand}"
                        CommandParameter="advanced">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Border Classes="leadingIcon">
                            <TextBlock Text="⚒"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Spacing="3">
                            <TextBlock Text="进阶配置"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="提供多样化配置"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="20" />
                    </Grid>
                </Button>

                <Button Classes="toolRow last"
                        Command="{Binding ShowToolPageCommand}"
                        CommandParameter="application">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Border Classes="leadingIcon">
                            <TextBlock Text="⚙"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Spacing="3">
                            <TextBlock Text="应用程序"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="修改应用程序相关设置"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="20" />
                    </Grid>
                </Button>

                <TextBlock Classes="sectionHeader"
                           Text="其他" />
                <Button Classes="toolRow"
                        Command="{Binding ShowToolPageCommand}"
                        CommandParameter="disclaimer">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Border Classes="leadingIcon">
                            <TextBlock Text="§"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="免责声明"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="15" />
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="20" />
                    </Grid>
                </Button>
                <Button Classes="toolRow last"
                        Command="{Binding ShowToolPageCommand}"
                        CommandParameter="about">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Border Classes="leadingIcon">
                            <TextBlock Text="i"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16"
                                       FontWeight="Black" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="关于"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="15" />
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="20" />
                    </Grid>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <Grid IsVisible="{Binding IsLanguageToolPage}">
            <ScrollViewer>
                <StackPanel Margin="16,0,16,96"
                            Spacing="12">
                    <Button Classes="tonal"
                            HorizontalAlignment="Left"
                            Content="‹ 返回"
                            IsVisible="False"
                            Command="{Binding CloseToolPageCommand}" />
                    <Button Classes="choice"
                            Classes.active="{Binding IsDefaultLocale}"
                            Content="默认"
                            Command="{Binding SetLocaleCommand}"
                            CommandParameter="" />
                    <Button Classes="choice"
                            Classes.active="{Binding IsChineseLocale}"
                            Content="简体中文"
                            Command="{Binding SetLocaleCommand}"
                            CommandParameter="zh-Hans" />
                    <Button Classes="choice"
                            Classes.active="{Binding IsEnglishLocale}"
                            Content="English"
                            Command="{Binding SetLocaleCommand}"
                            CommandParameter="en" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsThemeToolPage}">
            <ScrollViewer>
                <StackPanel Margin="16,0,16,96"
                            Spacing="14">
                    <Button Classes="tonal"
                            HorizontalAlignment="Left"
                            Content="‹ 返回"
                            IsVisible="False"
                            Command="{Binding CloseToolPageCommand}" />
                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="主题模式"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="10">
                                <Button Classes="choice"
                                        Classes.active="{Binding IsLightTheme}"
                                        Content="浅色"
                                        Command="{Binding SetThemeModeCommand}"
                                        CommandParameter="light" />
                                <Button Grid.Column="1"
                                        Classes="choice"
                                        Classes.active="{Binding IsDarkTheme}"
                                        Content="深色"
                                        Command="{Binding SetThemeModeCommand}"
                                        CommandParameter="dark" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Classes="card">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Border Width="48"
                                    Height="48"
                                    CornerRadius="24"
                                    Background="{DynamicResource Brush.Accent}" />
                            <StackPanel Grid.Column="1"
                                        Spacing="4">
                                <TextBlock Text="主题色"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="当前使用 FlClash 风格的粉紫 Material 配色"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsBackupToolPage}">
            <ScrollViewer>
                <StackPanel Margin="0,0,0,96">
                    <Button Classes="toolRow"
                            IsVisible="False"
                            Command="{Binding CloseToolPageCommand}">
                        <TextBlock Text="‹ 返回"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                    </Button>
                    <TextBlock Classes="sectionHeader"
                               Text="本地" />
                    <Button Classes="toolRow"
                            Click="ExportBackupClick">
                        <StackPanel Spacing="3">
                            <TextBlock Text="备份"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="导出状态数据库和配置文件"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolRow last"
                            Click="RestoreBackupClick">
                        <StackPanel Spacing="3">
                            <TextBlock Text="恢复"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="从备份文件恢复配置和设置"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12" />
                        </StackPanel>
                    </Button>
                    <TextBlock Classes="sectionHeader"
                               Text="选项" />
                    <Border Classes="settingRow last">
                        <TextBlock Text="恢复策略: 全量恢复"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="15" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsAccessToolPage}"
              RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0"
                        Margin="16,0,16,10"
                        Spacing="10">
                    <Button Classes="tonal"
                        HorizontalAlignment="Left"
                        Content="‹ 返回"
                        IsVisible="False"
                        Command="{Binding CloseToolPageCommand}" />
                <CheckBox Content="启用访问控制"
                          IsChecked="{Binding AccessControlEnabled}" />
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                    <Button Classes="choice"
                            Classes.active="{Binding IsRejectSelectedAccessMode}"
                            Content="排除选中"
                            Command="{Binding SetAccessControlModeCommand}"
                            CommandParameter="rejectSelected" />
                    <Button Grid.Column="1"
                            Classes="choice"
                            Classes.active="{Binding IsAcceptSelectedAccessMode}"
                            Content="仅允许选中"
                            Command="{Binding SetAccessControlModeCommand}"
                            CommandParameter="acceptSelected" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="8">
                    <TextBox Text="{Binding AccessSearchText}"
                             PlaceholderText="搜索应用或包名" />
                    <Button Grid.Column="1"
                            Content="刷新"
                            Command="{Binding LoadInstalledApplicationsCommand}" />
                    <Button Grid.Column="2"
                            Classes="danger"
                            Content="清空"
                            Command="{Binding ClearAccessApplicationsCommand}" />
                </Grid>
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="8">
                    <CheckBox Content="隐藏系统应用"
                              IsChecked="{Binding AccessFilterSystemApps}" />
                    <CheckBox Grid.Column="1"
                              Content="隐藏无联网权限"
                              IsChecked="{Binding AccessFilterNoInternetApps}" />
                </Grid>
                <Button Classes="tonal"
                        HorizontalAlignment="Left"
                        Content="选择当前列表"
                        Command="{Binding SelectAllVisibleAccessApplicationsCommand}" />
                <TextBlock Text="{Binding AccessSelectedCount, StringFormat=已选择 {0} 个应用}"
                           Foreground="{DynamicResource Brush.TextSecondary}"
                           FontSize="12" />
            </StackPanel>

            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding VisibleInstalledApplications}"
                              Margin="16,0,16,96">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:InstalledApplicationItem">
                            <Border Classes="accessApp"
                                    Classes.active="{Binding IsSelected}"
                                    Margin="0,0,0,8">
                                <Button Classes="listItemButton"
                                        Command="{Binding #Root.DataContext.ToggleAccessApplicationCommand}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="12">
                                        <Border Width="36"
                                                Height="36"
                                                CornerRadius="18"
                                                Background="{DynamicResource Brush.SurfaceAlt}">
                                            <TextBlock Text="A"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.Accent}"
                                                       FontWeight="Black" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Spacing="3">
                                            <TextBlock Text="{Binding Label}"
                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                       FontSize="14"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Summary}"
                                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                                       FontSize="12"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="✓"
                                                   IsVisible="{Binding IsSelected}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.Accent}"
                                                   FontSize="18"
                                                   FontWeight="Black" />
                                    </Grid>
                                </Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsBasicConfigToolPage}">
            <ScrollViewer>
                <StackPanel Margin="0,0,0,96">
                    <Button Classes="toolRow">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="i"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="3">
                                <TextBlock Text="日志等级"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBlock Text="{Binding LogLevel}"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="›"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="20" />
                        </Grid>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="debug"
                                          Command="{Binding SetLogLevelCommand}"
                                          CommandParameter="debug" />
                                <MenuItem Header="info"
                                          Command="{Binding SetLogLevelCommand}"
                                          CommandParameter="info" />
                                <MenuItem Header="warning"
                                          Command="{Binding SetLogLevelCommand}"
                                          CommandParameter="warning" />
                                <MenuItem Header="error"
                                          Command="{Binding SetLogLevelCommand}"
                                          CommandParameter="error" />
                                <MenuItem Header="silent"
                                          Command="{Binding SetLogLevelCommand}"
                                          CommandParameter="silent" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Button Classes="toolRow">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="UA"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontSize="11"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="3">
                                <TextBlock Text="UA"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBlock Text="{Binding GlobalUaText}"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="›"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="20" />
                        </Grid>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="默认"
                                          Command="{Binding SetGlobalUaCommand}"
                                          CommandParameter="" />
                                <MenuItem Header="clash-verge/v2.4.2"
                                          Command="{Binding SetGlobalUaCommand}"
                                          CommandParameter="clash-verge/v2.4.2" />
                                <MenuItem Header="ClashforWindows/0.19.23"
                                          Command="{Binding SetGlobalUaCommand}"
                                          CommandParameter="ClashforWindows/0.19.23" />
                                <MenuItem Header="clash"
                                          Command="{Binding SetGlobalUaCommand}"
                                          CommandParameter="clash" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Border Classes="settingRow">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="⏱"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontSize="15" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="测速 URL"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBox Text="{Binding TestUrl}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="settingRow">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="P"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="端口"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBox Text="{Binding MixedPort}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="settingRow">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="H"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="3">
                                <TextBlock Text="Hosts"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBlock Text="使用当前配置文件中的 Hosts 映射"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="settingRow">
                        <CheckBox Content="IPv6"
                                  IsChecked="{Binding EnableIpv6}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="Allow LAN"
                                  IsChecked="{Binding AllowLan}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="统一延迟"
                                  IsChecked="{Binding UnifiedDelay}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="追加系统 DNS"
                                  IsChecked="{Binding DnsHijacking}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="进程匹配"
                                  IsChecked="{Binding FindProcess}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="TCP 并发"
                                  IsChecked="{Binding TcpConcurrent}" />
                    </Border>
                    <Border Classes="settingRow">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="M"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="6">
                                <CheckBox Content="Geo低内存模式"
                                          IsChecked="{Binding GeodataMemory}" />
                                <TextBlock Text="开启后使用 memconservative geodata-loader"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Classes="settingRow last">
                        <CheckBox Content="外部控制器"
                                  IsChecked="{Binding ExternalController}" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsAdvancedConfigToolPage}">
            <ScrollViewer>
                <StackPanel Margin="0,0,0,96">
                    <Button Classes="toolRow"
                            Command="{Binding ShowToolPageCommand}"
                            CommandParameter="network">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="VPN"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontSize="10"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="3">
                                <TextBlock Text="网络"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBlock Text="VPN、TUN、路由和栈模式"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="›"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="20" />
                        </Grid>
                    </Button>
                    <Button Classes="toolRow"
                            Command="{Binding ShowToolPageCommand}"
                            CommandParameter="dns">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="DNS"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontSize="10"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="3">
                                <TextBlock Text="DNS"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBlock Text="DNS 劫持和系统 DNS 策略"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="›"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="20" />
                        </Grid>
                    </Button>
                    <Button Classes="toolRow"
                            Command="{Binding ShowToolPageCommand}"
                            CommandParameter="rules">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="☰"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontSize="16" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="3">
                                <TextBlock Text="附加规则"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBlock Text="控制全局附加规则"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="›"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="20" />
                        </Grid>
                    </Button>
                    <Button Classes="toolRow last"
                            Command="{Binding ShowToolPageCommand}"
                            CommandParameter="scripts">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="JS"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontSize="11"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="3">
                                <TextBlock Text="脚本"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBlock Text="覆写脚本"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="›"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="20" />
                        </Grid>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsNetworkConfigToolPage}">
            <ScrollViewer>
                <StackPanel Margin="0,0,0,96">
                    <Border Classes="settingRow">
                        <CheckBox Content="VPN"
                                  IsChecked="{Binding EnableTun}" />
                    </Border>
                    <TextBlock Classes="sectionHeader"
                               Text="VPN" />
                    <Border Classes="settingRow">
                        <CheckBox Content="系统代理"
                                  IsChecked="{Binding SystemProxy}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="IPv6"
                                  IsChecked="{Binding EnableIpv6}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="DNS 劫持"
                                  IsChecked="{Binding DnsHijacking}" />
                    </Border>
                    <TextBlock Classes="sectionHeader"
                               Text="选项" />
                    <Button Classes="toolRow">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="3">
                                <TextBlock Text="栈模式"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBlock Text="{Binding StackText}"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="›"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="20" />
                        </Grid>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="system"
                                          Command="{Binding SetStackCommand}"
                                          CommandParameter="system" />
                                <MenuItem Header="gvisor"
                                          Command="{Binding SetStackCommand}"
                                          CommandParameter="gvisor" />
                                <MenuItem Header="mixed"
                                          Command="{Binding SetStackCommand}"
                                          CommandParameter="mixed" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Border Classes="settingRow last">
                        <StackPanel Spacing="6">
                            <TextBlock Text="路由地址"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBox Text="{Binding RouteAddressCsv}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsDnsConfigToolPage}">
            <ScrollViewer>
                <StackPanel Margin="0,0,0,96">
                    <Border Classes="settingRow">
                        <CheckBox Content="DNS 劫持"
                                  IsChecked="{Binding DnsHijacking}" />
                    </Border>
                    <Border Classes="settingRow last">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="DNS"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontSize="10"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="3">
                                <TextBlock Text="系统 DNS"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBlock Text="运行时由 Android VpnService 通知 libclash"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsRulesConfigToolPage}">
            <ScrollViewer>
                <StackPanel Margin="0,0,0,96">
                    <Border Classes="settingRow">
                        <StackPanel Spacing="3">
                            <TextBlock Text="路由地址"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="{Binding RouteAddressText}"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Classes="settingRow last">
                        <StackPanel Spacing="6">
                            <TextBlock Text="附加规则"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="15" />
                            <TextBlock Text="使用当前配置文件中的 rules 与运行时路由设置。"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsScriptsConfigToolPage}">
            <ScrollViewer>
                <StackPanel Margin="0,0,0,96">
                    <Border Classes="settingRow last">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Classes="leadingIcon">
                                <TextBlock Text="JS"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontSize="11"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="3">
                                <TextBlock Text="覆写脚本"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="15" />
                                <TextBlock Text="使用当前配置文件中的 script 覆写内容。"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsApplicationSettingsToolPage}">
            <ScrollViewer>
                <StackPanel Margin="0,0,0,96">
                    <Button Classes="toolRow"
                            IsVisible="False"
                            Command="{Binding CloseToolPageCommand}">
                        <TextBlock Text="‹ 返回"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                    </Button>
                    <Border Classes="settingRow">
                        <CheckBox Content="退出时最小化"
                                  IsChecked="{Binding MinimizeOnExit}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="自动启动"
                                  IsChecked="{Binding AutoRun}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="隐藏到最近任务外"
                                  IsChecked="{Binding Hidden}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="标签页动画"
                                  IsChecked="{Binding AnimateTabs}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="日志"
                                  IsChecked="{Binding OpenLogs}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="自动关闭连接"
                                  IsChecked="{Binding CloseConnections}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="仅统计代理"
                                  IsChecked="{Binding OnlyStatisticsProxy}" />
                    </Border>
                    <Border Classes="settingRow">
                        <CheckBox Content="崩溃统计"
                                  IsChecked="{Binding Crashlytics}" />
                    </Border>
                    <Border Classes="settingRow last">
                        <CheckBox Content="自动检查更新"
                                  IsChecked="{Binding AutoCheckUpdates}" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsDisclaimerToolPage}">
            <ScrollViewer>
                <StackPanel Margin="16,0,16,96"
                            Spacing="14">
                    <Button Classes="tonal"
                            HorizontalAlignment="Left"
                            Content="‹ 返回"
                            IsVisible="False"
                            Command="{Binding CloseToolPageCommand}" />
                    <Border Classes="card">
                        <TextBlock Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Text="本项目仅用于网络代理客户端技术验证。使用者需要自行确认所在地区法律法规、订阅来源和网络行为合规性。开发者不提供任何节点服务，也不对第三方配置内容负责。" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsAboutToolPage}">
            <ScrollViewer>
                <StackPanel Margin="16,0,16,96"
                            Spacing="16">
                    <Button Classes="tonal"
                            HorizontalAlignment="Left"
                            Content="‹ 返回"
                            IsVisible="False"
                            Command="{Binding CloseToolPageCommand}" />
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="16">
                        <Image Source="avares://Aureline/Assets/Icon.png"
                               Width="64"
                               Height="64" />
                        <StackPanel Grid.Column="1"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Aureline"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="22"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Avalonia Android"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="13" />
                        </StackPanel>
                    </Grid>
                    <Border Classes="card">
                        <TextBlock Text="支持 libclash、clash-rs、libmeow 多核心的 Android 客户端。"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
