<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mihomo.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="760"
             x:Class="Mihomo.Views.Pages.ToolsPageView"
             x:DataType="vm:MainViewModel">
    <ScrollViewer>
        <StackPanel Margin="0,0,0,96">
            <TextBlock Classes="sectionHeader"
                       Text="设置" />
            <Border Classes="settingRow">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="14">
                    <Border Classes="leadingIcon">
                        <TextBlock Text="文"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontWeight="Black" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                Spacing="3"
                                VerticalAlignment="Center">
                        <TextBlock Text="语言"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="15" />
                        <TextBlock Text="默认"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="›"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="20" />
                </Grid>
            </Border>

            <Border Classes="settingRow">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="14">
                    <Border Classes="leadingIcon">
                        <TextBlock Text="◐"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontSize="16" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                Spacing="3"
                                VerticalAlignment="Center">
                        <TextBlock Text="主题"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="15" />
                        <TextBlock Text="设置深色模式，调整色彩"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="›"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="20" />
                </Grid>
            </Border>

            <Border Classes="settingRow">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="14">
                    <Border Classes="leadingIcon">
                        <TextBlock Text="☁"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontSize="16" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                Spacing="3"
                                VerticalAlignment="Center">
                        <TextBlock Text="备份和恢复"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="15" />
                        <TextBlock Text="备份和恢复配置"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="›"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="20" />
                </Grid>
            </Border>

            <Border Classes="settingRow last">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="14">
                    <Border Classes="leadingIcon">
                        <TextBlock Text="☷"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontSize="16" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                Spacing="3"
                                VerticalAlignment="Center">
                        <TextBlock Text="应用设置"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="15" />
                        <TextBlock Text="应用行为和调试选项"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="›"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="20" />
                </Grid>
            </Border>

            <TextBlock Classes="sectionHeader"
                       Text="订阅" />
            <Border Classes="settingRow">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="14">
                    <Border Classes="leadingIcon">
                        <TextBlock Text="URL"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontSize="11"
                                   FontWeight="Black" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Text="远程订阅"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="15" />
                        <TextBox Text="{Binding SubscriptionUrl}"
                                 PlaceholderText="https://example.com/sub.yaml" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="settingRow last">
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="8">
                    <Button Classes="primary"
                            Content="导入订阅"
                            Command="{Binding ImportSubscriptionCommand}" />
                    <Button Grid.Column="1"
                            Content="校验配置"
                            Command="{Binding ValidateConfigCommand}" />
                </Grid>
            </Border>

            <TextBlock Classes="sectionHeader"
                       Text="配置文件" />
            <Border Classes="settingRow">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="14">
                    <Border Classes="leadingIcon">
                        <TextBlock Text="H"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontWeight="Black" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Text="Home"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="15" />
                        <TextBox Text="{Binding HomeDirectory}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="settingRow">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="14">
                    <Border Classes="leadingIcon">
                        <TextBlock Text="Y"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontWeight="Black" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Text="config.yaml"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="15" />
                        <TextBox Text="{Binding ConfigPath}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="settingRow last">
                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">
                    <Button Content="保存"
                            Command="{Binding SaveConfigCommand}" />
                    <Button Grid.Column="1"
                            Content="重载"
                            Command="{Binding ReloadConfigCommand}" />
                    <Button Grid.Column="2"
                            Classes="danger"
                            Content="重置"
                            Command="{Binding ResetConfigCommand}" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
