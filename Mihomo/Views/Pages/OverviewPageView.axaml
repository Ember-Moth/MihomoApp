<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Mihomo.Views.Controls"
             xmlns:vm="using:Mihomo.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="760"
             x:Class="Mihomo.Views.Pages.OverviewPageView"
             x:DataType="vm:MainViewModel">
    <ScrollViewer>
        <StackPanel Margin="16,16,16,96"
                    Spacing="14">
            <Border Classes="dashboardCard"
                    MinHeight="174">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Text="⎍"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="18" />
                            <TextBlock Text="网络速度"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DownloadSpeed}"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="12" />
                    </Grid>

                    <Grid Grid.Row="1"
                          RowDefinitions="Auto,*"
                          RowSpacing="12">
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Text="上传"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           FontSize="12" />
                                <TextBlock Text="{Binding UploadSpeed}"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Spacing="2">
                                <TextBlock Text="下载"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           FontSize="12" />
                                <TextBlock Text="{Binding DownloadSpeed}"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>

                        <controls:SpeedChart Grid.Row="1"
                                             PrimarySamples="{Binding DownloadSpeedSamples}"
                                             SecondarySamples="{Binding UploadSpeedSamples}"
                                             PrimaryStroke="{DynamicResource Brush.Accent}"
                                             SecondaryStroke="{DynamicResource Brush.Info}" />
                    </Grid>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="14"
                  RowSpacing="14">
                <Border Classes="dashboardCard"
                        MinHeight="112">
                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Text="⇄"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                            <TextBlock Text="出站模式"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Bottom"
                                    Spacing="4">
                            <Button Classes="outboundMode"
                                    Classes.active="{Binding IsRuleMode}"
                                    Content="Rule"
                                    Command="{Binding ChangeOutboundModeCommand}"
                                    CommandParameter="rule" />
                            <Button Classes="outboundMode"
                                    Classes.active="{Binding IsGlobalMode}"
                                    Content="Global"
                                    Command="{Binding ChangeOutboundModeCommand}"
                                    CommandParameter="global" />
                            <Button Classes="outboundMode"
                                    Classes.active="{Binding IsDirectMode}"
                                    Content="Direct"
                                    Command="{Binding ChangeOutboundModeCommand}"
                                    CommandParameter="direct" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="dashboardCard"
                        MinHeight="112">
                    <Grid RowDefinitions="Auto,*">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="8">
                            <TextBlock Text="{Binding PublicIpCountryMark}"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                            <TextBlock Text="网络检测"
                                       Grid.Column="1"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <Button Grid.Column="2"
                                    Classes="iconButton"
                                    Width="24"
                                    Height="24"
                                    MinWidth="24"
                                    MinHeight="24"
                                    Content="i"
                                    Command="{Binding RefreshNetworkDetectionCommand}" />
                        </Grid>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding NetworkDetectionText}"
                                   VerticalAlignment="Bottom"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   MaxLines="1"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Classes="dashboardCard"
                        MinHeight="112">
                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Text="◌"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                            <TextBlock Text="流量统计"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <Grid Grid.Row="1"
                              ColumnDefinitions="48,*"
                              ColumnSpacing="10"
                              VerticalAlignment="Bottom">
                            <Border Width="48"
                                    Height="48"
                                    CornerRadius="24"
                                    Background="{DynamicResource Brush.AccentSurface}">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="14"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource Brush.Surface}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="5"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalUpload}"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TotalDownload}"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="1"
                        Classes="dashboardCard"
                        MinHeight="112">
                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Text="▣"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" />
                            <TextBlock Text="内网地址"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding VpnIntranetAddress}"
                                   VerticalAlignment="Bottom"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
