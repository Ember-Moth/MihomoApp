<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mihomo.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="760"
             x:Class="Mihomo.Views.Pages.ProfilesPageView"
             x:DataType="vm:MainViewModel">
    <ScrollViewer>
        <StackPanel Margin="16"
                    Spacing="14">
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="3">
                        <TextBlock Text="订阅"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   FontSize="19"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="导入远程配置到当前 config.yaml"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   FontSize="12" />
                    </StackPanel>

                    <TextBox Text="{Binding SubscriptionUrl}"
                             PlaceholderText="https://example.com/sub.yaml" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button Classes="primary"
                                Content="导入订阅"
                                Command="{Binding ImportSubscriptionCommand}" />
                        <Button Grid.Column="1"
                                Content="校验配置"
                                Command="{Binding ValidateConfigCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="当前配置"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               FontSize="17"
                               FontWeight="SemiBold" />
                    <TextBox Text="{Binding ConfigPath}"
                             PlaceholderText="/data/user/0/.../files/config.yaml" />
                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="8">
                        <Button Content="保存"
                                Command="{Binding SaveConfigCommand}" />
                        <Button Grid.Column="1"
                                Content="重载"
                                Command="{Binding ReloadConfigCommand}" />
                        <Button Grid.Column="2"
                                Content="重置"
                                Command="{Binding ResetConfigCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Text="运行入口"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               FontSize="17"
                               FontWeight="SemiBold" />
                    <TextBox Text="{Binding ApiBaseAddress}"
                             PlaceholderText="http://127.0.0.1:9090" />
                    <TextBlock Text="用于查询 mihomo external-controller API"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
