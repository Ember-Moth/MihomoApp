<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mihomo.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="760"
             x:Name="Root"
             x:Class="Mihomo.Views.Pages.ProxiesPageView"
             x:DataType="vm:MainViewModel">
    <Grid RowDefinitions="Auto,Auto,*"
          Margin="16"
          RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
                <TextBlock Text="代理"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding ProxySummary}"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           FontSize="12" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="刷新"
                    Command="{Binding RefreshProxiesCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ProxyGroups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProxyGroupItem">
                        <Button Margin="0,0,8,0"
                                MinWidth="126"
                                Command="{Binding DataContext.SelectGroupCommand, ElementName=Root}"
                                CommandParameter="{Binding}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Summary}"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Classes="card"
                Padding="0">
            <Grid RowDefinitions="Auto,*">
                <Border Padding="14"
                        BorderBrush="{StaticResource Brush.BorderMuted}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding SelectedGroup.Name}"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       FontSize="17"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedGroup.Summary}"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedGroup.Now}"
                                   Foreground="{StaticResource Brush.Accent}"
                                   MaxWidth="130"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding SelectedGroup.Nodes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProxyNodeItem">
                                <Button Margin="12,10,12,0"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding DataContext.SelectProxyCommand, ElementName=Root}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource Brush.TextPrimary}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Type}"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Spacing="3"
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding DelayText}"
                                                       Foreground="{StaticResource Brush.Warning}"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock Text="当前"
                                                       IsVisible="{Binding IsSelected}"
                                                       Foreground="{StaticResource Brush.Accent}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
