<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mihomo.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="760"
             x:Name="Root"
             x:Class="Mihomo.Views.Pages.ProxiesPageView"
             x:DataType="vm:MainViewModel">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.PageBackground}"
                BorderBrush="{DynamicResource Brush.BorderMuted}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ProxyGroups}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProxyGroupItem">
                                <Button Classes="proxyTab"
                                        Classes.active="{Binding IsSelected}"
                                        Command="{Binding DataContext.SelectGroupCommand, ElementName=Root}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   FontSize="14"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Height="3"
                                                CornerRadius="2"
                                                Background="{DynamicResource Brush.Accent}"
                                                IsVisible="{Binding IsSelected}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Column="1"
                        Classes="iconButton"
                        Margin="2,4,8,4"
                        Content="⌄" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="16,16,16,96"
                        Spacing="0">
                <Border Classes="card"
                        IsVisible="{Binding MissingSelectedGroup}">
                    <StackPanel Spacing="8"
                                HorizontalAlignment="Center">
                        <TextBlock Text="暂无代理"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="启动核心后刷新"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="12"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Classes="card"
                        IsVisible="{Binding MissingVisibleProxyNodes}">
                    <TextBlock Text="没有匹配的节点"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               HorizontalAlignment="Center" />
                </Border>

                <ItemsControl ItemsSource="{Binding VisibleProxyNodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProxyNodeItem">
                            <Border Width="171"
                                    Classes="proxyCard"
                                    Classes.active="{Binding IsSelected}"
                                    Margin="0,0,8,8">
                                <Grid>
                                    <Button Classes="proxyPick"
                                            Command="{Binding DataContext.SelectProxyCommand, ElementName=Root}"
                                            CommandParameter="{Binding}">
                                        <Grid RowDefinitions="*,Auto"
                                              RowSpacing="8">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                       FontSize="14"
                                                       MaxLines="2"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Grid Grid.Row="1"
                                                  ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8">
                                                <TextBlock Text="{Binding TypeText}"
                                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                                           FontSize="12"
                                                           MaxLines="1"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Button Grid.Column="1"
                                                        MinHeight="24"
                                                        Padding="4,0"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        Content="{Binding DelayText}"
                                                        Foreground="{DynamicResource Brush.Warning}"
                                                        FontSize="12"
                                                        Command="{Binding DataContext.TestProxyDelayCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </Grid>
                                    </Button>

                                    <Border Width="24"
                                            Height="24"
                                            CornerRadius="12"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Background="{DynamicResource Brush.Accent}"
                                            IsVisible="{Binding IsSelected}">
                                        <TextBlock Text="✓"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.AccentForeground}"
                                                   FontSize="12"
                                                   FontWeight="Black" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
