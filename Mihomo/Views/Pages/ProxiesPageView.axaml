<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mihomo.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="760"
             x:Name="Root"
             x:Class="Mihomo.Views.Pages.ProxiesPageView"
             x:DataType="vm:MainViewModel">
    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.PageBackground}"
                BorderBrush="{DynamicResource Brush.BorderMuted}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ProxyGroups}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProxyGroupItem">
                                <Button Classes="proxyTab"
                                        Classes.active="{Binding IsSelected}"
                                        Command="{Binding DataContext.SelectGroupCommand, ElementName=Root}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   FontSize="14"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Height="3"
                                                CornerRadius="2"
                                                Background="{DynamicResource Brush.Accent}"
                                                IsVisible="{Binding IsSelected}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Column="1"
                        Classes="iconButton"
                        Margin="2,4,8,4"
                        Content="⌄"
                        Command="{Binding ToggleProxyGroupListCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                IsVisible="{Binding IsProxySearchVisible}"
                Padding="16,10"
                Background="{DynamicResource Brush.PageBackground}"
                BorderBrush="{DynamicResource Brush.BorderMuted}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <TextBox Text="{Binding ProxySearchText}"
                         PlaceholderText="搜索节点" />
                <Button Grid.Column="1"
                        Classes="iconButton"
                        Content="×"
                        Command="{Binding ClearProxySearchCommand}" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      x:Name="ProxyPageHost"
                      RenderTransformOrigin="0.5,0.5">
            <StackPanel Margin="12,16,12,96"
                        Spacing="0">
                <Border Classes="card"
                        IsVisible="{Binding MissingSelectedGroup}">
                    <StackPanel Spacing="8"
                                HorizontalAlignment="Center">
                        <TextBlock Text="暂无代理"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="启动核心后刷新"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   FontSize="12"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Classes="card"
                        IsVisible="{Binding MissingVisibleProxyNodes}">
                    <TextBlock Text="没有匹配的节点"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               HorizontalAlignment="Center" />
                </Border>

                <ItemsControl ItemsSource="{Binding VisibleProxyNodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProxyNodeItem">
                            <Button Classes="proxyCardButton"
                                    Classes.active="{Binding IsSelected}"
                                    Margin="4"
                                    Command="{Binding DataContext.SelectProxyCommand, ElementName=Root}"
                                    CommandParameter="{Binding}">
                                <Grid>
                                    <Grid RowDefinitions="*,Auto"
                                          RowSpacing="8">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   FontSize="14"
                                                   MaxLines="2"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Grid Grid.Row="1"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">
                                            <TextBlock Text="{Binding TypeText}"
                                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                                       FontSize="12"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1"
                                                    Classes="delayChip"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DelayText}"
                                                           Foreground="{DynamicResource Brush.Warning}"
                                                           FontSize="12" />
                                            </Border>
                                        </Grid>
                                    </Grid>

                                    <Border Width="24"
                                            Height="24"
                                            CornerRadius="12"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Background="{DynamicResource Brush.Accent}"
                                            IsVisible="{Binding IsSelected}">
                                        <TextBlock Text="✓"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.AccentForeground}"
                                                   FontSize="12"
                                                   FontWeight="Black" />
                                    </Border>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.RowSpan="3"
                IsVisible="{Binding IsProxyGroupListVisible}"
                Background="#99000000">
            <Grid RowDefinitions="*,Auto">
                <Button Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{Binding HideProxyGroupListCommand}" />
                <Border Grid.Row="1"
                        Classes="bottomSheet">
                    <StackPanel>
                        <Grid Height="48"
                              ColumnDefinitions="48,*,48">
                            <TextBlock Grid.Column="1"
                                       Text="策略组"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <Button Grid.Column="2"
                                    Classes="iconButton"
                                    Content="×"
                                    Command="{Binding HideProxyGroupListCommand}" />
                        </Grid>
                        <ScrollViewer MaxHeight="420">
                            <ItemsControl ItemsSource="{Binding ProxyGroups}"
                                          Margin="0,0,0,28">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProxyGroupItem">
                                        <Button Classes="toolRow"
                                                Command="{Binding #Root.DataContext.SelectGroupCommand}"
                                                CommandParameter="{Binding}">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="12">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               MaxLines="1"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Summary}"
                                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                                               FontSize="12"
                                                               MaxLines="1"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="✓"
                                                           IsVisible="{Binding IsSelected}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource Brush.Accent}"
                                                           FontSize="18"
                                                           FontWeight="Black" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
